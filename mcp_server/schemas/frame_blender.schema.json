{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "frame_blender",
  "type": "object",
  "required": ["frame_b64", "perturbation_b64", "boxes", "alpha"],
  "properties": {
    "frame_b64": { "type": "string", "minLength": 1 },
    "perturbation_b64": { "type": "string", "minLength": 1 },
    "boxes": {
      "type": "array",
      "items": {
        "type": "array",
        "items": { "type": "number" },
        "minItems": 4,
        "maxItems": 4
      }
    },
    "alpha": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
  },
  "additionalProperties": false
}
